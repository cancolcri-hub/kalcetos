# Kalcetos — variables de entorno
#
# IMPORTANTE:
# - Copia este archivo a .env.local y rellena valores ahí.
# - NUNCA commitees .env.local (ya está en .gitignore).
# - SUPABASE_SERVICE_ROLE_KEY y STRIPE_SECRET_KEY NUNCA expuestas al cliente:
#   no prefijar con NEXT_PUBLIC_, no usar en Client Components.
# - Durante desarrollo: usar claves Stripe TEST (pk_test_..., sk_test_...).
#   Pasar a LIVE (pk_live_..., sk_live_...) solo en Fase 1.8 (deploy a Vercel).

# ---------- Site ----------
NEXT_PUBLIC_SITE_URL=https://kalcetos.shop
NEXT_PUBLIC_SITE_NAME=Kalcetos

# ---------- Supabase (EU, Frankfurt) ----------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...                    # solo server, NUNCA al cliente

# ---------- Stripe ----------
# Dev: pk_test_... / sk_test_...
# Prod: pk_live_... / sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx                         # generado por `stripe listen` en dev,
                                                        # o por el dashboard en prod

# ---------- Resend (email transaccional) ----------
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=hola@kalcetos.shop                    # dominio verificado en Resend (SPF/DKIM/DMARC)

# ---------- Meta (Pixel + CAPI, para SKILL 04) ----------
NEXT_PUBLIC_META_PIXEL_ID=000000000000000
META_CAPI_ACCESS_TOKEN=EAAxxx
META_TEST_EVENT_CODE=                                   # opcional, solo durante validación en Events Manager

# ---------- Opcionales ----------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
